# Prefer OpenRouter for this demo (OpenAI-compatible).
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OVERMIND_DEMO_MODEL=openai/gpt-4o-mini

# Or native OpenAI instead:
# OPENAI_API_KEY=sk-...
# OVERMIND_DEMO_MODEL=gpt-4o-mini

# Local FHIR stack (compose defaults; override only if needed)
# FHIR_MCP_URL=http://fhir-mcp-server:8004
# FHIR_BASE_URL=http://hapi-fhir:8080/fhir

# Jobs wizard default API is http://localhost:8000 (VITE_API_BASE_URL).
# From healthcare-executioner use host.docker.internal (or your OrbStack host).
OVERMIND_API_URL=http://host.docker.internal:8000
OVERMIND_API_KEY=
# Optional for command leasing; used for SDK tracing attribution
OVERMIND_PROJECT_ID=
OVERMIND_AGENT_ID=
